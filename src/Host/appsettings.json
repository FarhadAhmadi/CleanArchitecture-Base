{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": ""
  },
  "SecretManagement": {
    "UseAzureKeyVault": false,
    "KeyVaultUri": ""
  },
  "RabbitMq": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "ExchangeName": "cleanarchitecture.events",
    "QueueName": "cleanarchitecture.events.queue",
    "RoutingKey": "#",
    "ConsumerEnabled": true
  },
  "RedisCache": {
    "Enabled": false,
    "ConnectionString": "",
    "InstanceName": "clean-architecture:"
  },
  "PermissionCache": {
    "AbsoluteExpirationSeconds": 300
  },
  "Jwt": {
    "Secret": "",
    "PreviousSecrets": [],
    "Issuer": "",
    "Audience": "",
    "ExpirationInMinutes": 60
  },
  "AuthSecurity": {
    "PasswordMinLength": 12,
    "PasswordRequireDigit": true,
    "PasswordRequireLowercase": true,
    "PasswordRequireUppercase": true,
    "PasswordRequireNonAlphanumeric": true,
    "PasswordRequiredUniqueChars": 6,
    "PasswordHistoryLimit": 5,
    "BreachedPasswordDenyList": [ "password123", "qwerty123", "admin12345" ],
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15,
    "EmailVerificationCodeExpiresInSeconds": 120,
    "EmailVerificationResendCooldownSeconds": 60,
    "EmailVerificationMaxFailedAttempts": 5,
    "EmailVerificationBlockMinutes": 15,
    "PasswordResetCodeExpiresInSeconds": 600,
    "PasswordResetRequestCooldownSeconds": 60
  },
  "ExternalOAuth": {
    "Google": {
      "Enabled": false,
      "ClientId": "",
      "ClientSecret": ""
    },
    "Meta": {
      "Enabled": false,
      "AppId": "",
      "AppSecret": ""
    }
  },
  "RefreshToken": {
    "ExpirationInDays": 14
  },
  "AuthorizationBootstrap": {
    "SeedDefaults": true,
    "UserRoleName": "user",
    "AdminRoleName": "admin",
    "AdminEmails": []
  },
  "ApiSecurity": {
    "AllowedOrigins": [],
    "MaxRequestBodySizeMb": 10,
    "MaxRequestHeadersTotalSizeKb": 32,
    "MaxRequestHeaderCount": 100,
    "RequestHeadersTimeoutSeconds": 15,
    "RequestTimeoutSeconds": 30,
    "RateLimitPermitLimit": 100,
    "RateLimitWindowSeconds": 60,
    "PerUserRateLimitPermitLimit": 60,
    "PerIpRateLimitPermitLimit": 120,
    "PublicFileLinkRateLimitPermitLimit": 20,
    "PublicFileLinkRateLimitWindowSeconds": 60,
    "EnableSecurityHeaders": true,
    "UseHsts": true,
    "HideServerHeader": true,
    "EnforceJsonAcceptHeader": false
  },
  "DatabaseMigrations": {
    "ApplyOnStartup": false,
    "RunAuthorizationSeed": true,
    "RunSampleDataSeed": false
  },
  "Telemetry": {
    "ServiceName": "CleanArchitecture.WebApi",
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "// Levels (commented)": "Verbose, Debug, Information, Warning, Error, Fatal",
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "LogSinks": {
    "EnableConsole": true,
    "Provider": "Seq",
    //"Provider": "Elasticsearch",
    "SeqServerUrl": "http://localhost:8081",
    "ElasticsearchNodeUrl": "http://localhost:9200",
    "ElasticsearchIndexFormat": "clean-architecture-logs-{0:yyyy.MM.dd}"
  },
  "LoggingPlatform": {
    "MaxBulkItems": 200,
    "MaxPayloadSizeKb": 64,
    "QueueCapacity": 50000,
    "RetryMaxAttempts": 6,
    "RetryInitialDelayMs": 200
  },
  "Outbox": {
    "BatchSize": 100,
    "PollingIntervalSeconds": 5,
    "MaxRetryCount": 10
  },
  "Scheduler": {
    "SeedDefaults": true,
    "PollingIntervalSeconds": 15,
    "MaxDueJobsPerIteration": 100,
    "LockLeaseSeconds": 120,
    "MisfireGraceSeconds": 30,
    "DefaultQuarantineMinutes": 60,
    "NodeId": ""
  },
  "OperationalSlo": {
    "MaxCorruptedLogRatePercent": 0.5,
    "MaxOutboxPending": 1000,
    "MaxOutboxFailed": 0,
    "MaxOutboxBacklogAgeSeconds": 300,
    "MaxIngestionQueueDepth": 10000
  },
  "Idempotency": {
    "Enabled": true,
    "ExpirationMinutes": 30,
    "MaxResponseBodyBytes": 65536,
    "CleanupIntervalMinutes": 10,
    "CleanupBatchSize": 500
  },
  "OperationalAlerting": {
    "Enabled": false,
    "PollingIntervalSeconds": 60,
    "CooldownMinutes": 15,
    "WebhookUrls": [],
    "RunbookBaseUrl": "",
    "PagerDutyRoutingKey": "",
    "PagerDutyEventsApiUrl": "https://events.pagerduty.com/v2/enqueue"
  },
  "FileStorage": {
    "Enabled": true,
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "Bucket": "nextgen-files",
    "UseSsl": false,
    "CreateBucketIfMissing": true,
    "PresignedUrlExpiryMinutes": 15,
    "ObjectPrefix": "files",
    "StagingObjectPrefix": "staging",
    "RetryMaxAttempts": 3,
    "RetryBaseDelayMs": 200,
    "RequestTimeoutSeconds": 15,
    "CircuitBreakerFailureRatioPercent": 50,
    "CircuitBreakerSamplingSeconds": 30,
    "CircuitBreakerMinimumThroughput": 20,
    "CircuitBreakerBreakSeconds": 20,
    "EnableMissingObjectPlaceholder": true
  },
  "FileUploadProcessing": {
    "Enabled": true,
    "PollingSeconds": 3,
    "BatchSize": 20,
    "MaxRetryCount": 6
  },
  "FileReconciliation": {
    "Enabled": true,
    "PollingSeconds": 120,
    "BatchSize": 100,
    "PendingStaleMinutes": 30
  },
  "FileValidation": {
    "MaxFileSizeMb": 50,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".pdf", ".docx", ".zip", ".rar", ".mp4", ".mov", ".txt", ".mp3", ".wav", ".m4a" ]
  },
  "ClamAv": {
    "Enabled": false,
    "Host": "localhost",
    "Port": 3310,
    "TimeoutSeconds": 20
  },
  "Notifications": {
    "Enabled": true,
    "MaxRetries": 5,
    "BaseRetryDelaySeconds": 10,
    "DispatchBatchSize": 100,
    "DispatchPollingSeconds": 5,
    "PerUserPerMinuteLimit": 120,
    "SensitiveDataEncryptionKey": "change-me-notification-key",
    "Email": {
      "Enabled": false,
      "Host": "",
      "Port": 587,
      "UseSsl": true,
      "UserName": "",
      "Password": "",
      "FromAddress": "",
      "FromName": "NextGen Notifications",
      "IsBodyHtml": true
    },
    "Sms": {
      "Enabled": false,
      "BaseUrl": "",
      "EndpointPath": "send",
      "ApiKey": "",
      "ApiKeyHeaderName": "X-API-Key",
      "UseBearerToken": true,
      "SenderId": ""
    },
    "Slack": {
      "Enabled": false,
      "WebhookUrl": "",
      "BotToken": "",
      "PostMessageApiUrl": "https://slack.com/api/chat.postMessage"
    },
    "Teams": {
      "Enabled": false,
      "WebhookUrl": ""
    },
    "Push": {
      "Enabled": false,
      "BaseUrl": "",
      "EndpointPath": "send",
      "ApiKey": "",
      "ApiKeyHeaderName": "X-API-Key",
      "UseBearerToken": true
    },
    "InApp": {
      "Enabled": true
    }
  }
}
